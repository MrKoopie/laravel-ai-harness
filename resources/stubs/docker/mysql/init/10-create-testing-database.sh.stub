#!/usr/bin/env bash
set -euo pipefail

mysql --user=root --password="${MYSQL_ROOT_PASSWORD:-}" <<EOSQL
CREATE DATABASE IF NOT EXISTS \`{{ testing_database_name }}\` CHARACTER SET {{ database_charset }} COLLATE {{ database_collation }};
GRANT ALL PRIVILEGES ON \`{{ testing_database_name }}\`.* TO '${MYSQL_USER:-root}'@'%';
EOSQL
