{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.dev/bin/ai-harness ai-harness:doctor",
                        "timeout": 60,
                        "statusMessage": "Checking Laravel AI Harness"
                    }
                ]
            }
        ]
    }
}
