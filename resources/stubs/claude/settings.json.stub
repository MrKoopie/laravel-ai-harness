{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "EnterWorktree",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-up.sh",
                        "timeout": 300,
                        "statusMessage": "Provisioning worktree (CoW clone, DB, migrate:fresh --seed, Herd)"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "ExitWorktree",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-down.sh",
                        "timeout": 60,
                        "statusMessage": "Tearing down worktree (Herd unlink, DROP DATABASE)"
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-session-start.sh",
                        "timeout": 600,
                        "statusMessage": "Provisioning worktree if needed (one-time per worktree)"
                    },
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/web-session-start.sh",
                        "timeout": 600,
                        "statusMessage": "Provisioning Claude Code on the web (composer + npm + SQLite)"
                    },
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.dev/bin/ai-harness ai-harness:doctor",
                        "timeout": 60,
                        "statusMessage": "Checking Laravel AI Harness"
                    }
                ]
            }
        ]
    }
}
