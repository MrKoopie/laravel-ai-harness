{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "EnterWorktree",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash -lc 'script=\"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-up.sh\"; [ ! -x \"$script\" ] || \"$script\"'",
                        "timeout": 300,
                        "statusMessage": "Provisioning worktree"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "ExitWorktree",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash -lc 'script=\"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-down.sh\"; [ ! -x \"$script\" ] || \"$script\"'",
                        "timeout": 60,
                        "statusMessage": "Tearing down worktree"
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash -lc 'script=\"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-session-start.sh\"; [ ! -x \"$script\" ] || \"$script\"'",
                        "timeout": 600,
                        "statusMessage": "Provisioning worktree if needed"
                    },
                    {
                        "type": "command",
                        "command": "bash -lc 'script=\"$CLAUDE_PROJECT_DIR/.claude/scripts/web-session-start.sh\"; [ ! -x \"$script\" ] || \"$script\"'",
                        "timeout": 600,
                        "statusMessage": "Provisioning Claude Code on the web"
                    },
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.dev/bin/ai-harness ai-harness:doctor",
                        "timeout": 60,
                        "statusMessage": "Checking Laravel AI Harness"
                    }
                ]
            }
        ]
    }
}
