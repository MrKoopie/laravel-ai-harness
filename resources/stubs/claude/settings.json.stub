{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "EnterWorktree",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-up.sh\"",
                        "timeout": 600,
                        "statusMessage": "Provisioning Laravel AI Harness worktree"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "ExitWorktree",
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-down.sh\"",
                        "timeout": 600,
                        "statusMessage": "Tearing down Laravel AI Harness worktree"
                    }
                ]
            }
        ],
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR/.claude/scripts/worktree-up.sh\"",
                        "timeout": 600,
                        "statusMessage": "Provisioning Laravel AI Harness worktree if needed"
                    },
                    {
                        "type": "command",
                        "command": "\"$CLAUDE_PROJECT_DIR/.dev/bin/ai-harness\" ai-harness:doctor",
                        "timeout": 60,
                        "statusMessage": "Checking Laravel AI Harness"
                    }
                ]
            }
        ]
    }
}
