#!/usr/bin/env bash
set -euo pipefail

stdin_json=""
if [[ ! -t 0 ]]; then
    stdin_json="$(cat || true)"
fi

json_value() {
    local key="${1}"

    [[ -n "${stdin_json}" ]] || return 0

    if command -v php >/dev/null 2>&1; then
        AI_HARNESS_JSON_KEY="${key}" php -r '
            $payload = json_decode(stream_get_contents(STDIN), true);
            if (! is_array($payload)) {
                exit(0);
            }

            $value = $payload;
            foreach (explode(".", getenv("AI_HARNESS_JSON_KEY") ?: "") as $segment) {
                if (! is_array($value) || ! array_key_exists($segment, $value)) {
                    exit(0);
                }

                $value = $value[$segment];
            }

            if (is_string($value)) {
                echo $value;
            }
        ' <<< "${stdin_json}"

        return
    fi

    case "${key}" in
        tool_response.worktreePath)
            printf '%s' "${stdin_json}" | sed -n 's/.*"worktreePath"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1
            ;;
        cwd)
            printf '%s' "${stdin_json}" | sed -n 's/.*"cwd"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1
            ;;
    esac
}

resolve_worktree_root() {
    local candidate="${1}"
    local root after name prefix

    root="$(git -C "${candidate}" rev-parse --show-toplevel 2>/dev/null || true)"
    if [[ -n "${root}" ]]; then
        printf '%s\n' "${root}"

        return
    fi

    if [[ "${candidate}" == *"/.claude/worktrees/"* ]]; then
        prefix="${candidate%%/.claude/worktrees/*}/.claude/worktrees"
        after="${candidate#*/.claude/worktrees/}"
        name="${after%%/*}"
        printf '%s\n' "${prefix}/${name}"

        return
    fi

    printf '%s\n' "${candidate}"
}

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)"
worktree_path="${1:-}"
is_explicit_worktree=false

if [[ -z "${worktree_path}" ]]; then
    worktree_path="$(json_value tool_response.worktreePath)"
    [[ -n "${worktree_path}" ]] && is_explicit_worktree=true
else
    is_explicit_worktree=true
fi

if [[ -z "${worktree_path}" ]]; then
    worktree_path="$(json_value cwd)"
fi

if [[ -z "${worktree_path}" ]]; then
    worktree_path="${PWD}"
fi

worktree_path="$(resolve_worktree_root "${worktree_path}")"

if [[ "${is_explicit_worktree}" != true && "${worktree_path}" != *"/.claude/worktrees/"* ]]; then
    exit 0
fi

if [[ ! -d "${worktree_path}" ]]; then
    printf 'worktree-up: worktree path does not exist: %s\n' "${worktree_path}" >&2
    exit 1
fi

worktree_path="$(cd -- "${worktree_path}" && pwd -P)"
local_environment="${worktree_path}/.codex/scripts/local-environment.sh"

if [[ ! -x "${local_environment}" ]]; then
    printf 'worktree-up: missing executable local environment script: %s\n' "${local_environment}" >&2
    exit 1
fi

marker="${worktree_path}/.claude/.ai-harness-worktree-provisioned"
if [[ -f "${marker}" ]]; then
    exit 0
fi

mkdir -p "${worktree_path}/.claude"

WORKTREE_PROFILE=codex \
CODEX_WORKTREE_PATH="${worktree_path}" \
bash "${local_environment}" setup

touch "${marker}"
