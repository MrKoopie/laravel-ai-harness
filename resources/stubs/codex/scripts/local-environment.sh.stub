#!/usr/bin/env bash
set -euo pipefail

action="${1:-setup}"
repo_root="${CODEX_WORKTREE_PATH:-}"
herd_workspace_enabled="${AI_HARNESS_HERD_WORKSPACE_ENABLED:-{{ herd_workspace_enabled }}}"
database_base_name="{{ database_name }}"
database_charset="{{ database_charset }}"
database_collation="{{ database_collation }}"

if [[ -z "${repo_root}" ]]; then
    repo_root="$(git rev-parse --show-toplevel)"
fi

artisan() {
    "${repo_root}/.dev/bin/ai-harness" "$@"
}

sail_runtime_available() {
    [[ -x ./vendor/bin/sail ]] || return 1

    if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
        return 0
    fi

    if command -v podman >/dev/null 2>&1 && podman info >/dev/null 2>&1; then
        return 0
    fi

    return 1
}

php_runtime() {
    if sail_runtime_available; then
        ./vendor/bin/sail php "$@"

        return
    fi

    if command -v herd >/dev/null 2>&1; then
        herd php "$@"

        return
    fi

    php "$@"
}

composer_runtime_available() {
    sail_runtime_available || command -v herd >/dev/null 2>&1 || command -v composer >/dev/null 2>&1
}

composer_runtime() {
    if sail_runtime_available; then
        ./vendor/bin/sail composer "$@"

        return
    fi

    if command -v herd >/dev/null 2>&1; then
        herd composer "$@"

        return
    fi

    composer "$@"
}

codex_workspace_requested() {
    [[ "${WORKTREE_PROFILE:-}" == "codex" ]]
}

herd_workspace_requested() {
    [[ "${herd_workspace_enabled}" == "1" ]] || return 1
    [[ "${WORKTREE_PROFILE:-}" == "codex" ]] || return 1

    command -v herd >/dev/null 2>&1
}

herd_site_name() {
    local project_name parent_name path_hash base_name max_base_length site_name

    project_name="$(basename "${repo_root}")"
    parent_name="$(basename "$(dirname "${repo_root}")")"
    path_hash="$(printf '%s' "${repo_root}" | cksum | awk '{print $1}')"
    base_name="$(printf '%s' "${project_name}-${parent_name}" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
    max_base_length=$((63 - ${#path_hash} - 1))
    base_name="${base_name:0:${max_base_length}}"
    base_name="${base_name%-}"
    site_name="${base_name:-codex-worktree}-${path_hash}"

    printf '%s\n' "${site_name}"
}

worktree_database_name() {
    local base path_hash max_base_length database_name

    base="${database_base_name:-$(basename "${repo_root}")}"
    base="$(printf '%s' "${base}" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//')"
    path_hash="$(printf '%s' "${repo_root}" | cksum | awk '{print $1}')"
    max_base_length=$((64 - ${#path_hash} - 1))
    database_name="${base:0:${max_base_length}}"

    if [[ -n "${database_name}" ]]; then
        database_name="${database_name}_${path_hash}"
    else
        database_name="codex_worktree_${path_hash}"
    fi

    printf '%s\n' "${database_name}"
}

worktree_testing_database_name() {
    local base path_hash suffix max_base_length database_name

    base="${database_base_name:-$(basename "${repo_root}")}"
    base="$(printf '%s' "${base}" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/_/g; s/^_+//; s/_+$//')"
    path_hash="$(printf '%s' "${repo_root}" | cksum | awk '{print $1}')"
    suffix="_testing_"
    max_base_length=$((64 - ${#path_hash} - ${#suffix}))
    database_name="${base:0:${max_base_length}}"

    if [[ -n "${database_name}" ]]; then
        database_name="${database_name}${suffix}${path_hash}"
    else
        database_name="codex_worktree_testing_${path_hash}"
    fi

    printf '%s\n' "${database_name}"
}

env_value() {
    file_env_value .env "${1}"
}

file_env_value() {
    local file="${1}" key="${2}" line value

    if [[ ! -f "${file}" ]]; then
        return 1
    fi

    line="$(grep -E "^${key}=" "${file}" | tail -n 1 || true)"
    value="${line#${key}=}"
    value="${value%\"}"
    value="${value#\"}"
    value="${value%\'}"
    value="${value#\'}"

    [[ "${line}" == "${key}="* ]] || return 1
    printf '%s\n' "${value}"
}

set_env_value() {
    set_env_file_value .env "${1}" "${2}"
}

set_env_file_value() {
    local file="${1}" key="${2}" value="${3}" temporary_file

    temporary_file="$(mktemp)"

    if [[ -f "${file}" ]]; then
        awk -v key="${key}" -v value="${value}" '
            BEGIN { replaced = 0 }
            $0 ~ "^" key "=" {
                print key "=" value
                replaced = 1
                next
            }
            { print }
            END {
                if (replaced == 0) {
                    print key "=" value
                }
            }
        ' "${file}" > "${temporary_file}"
    else
        printf '%s=%s\n' "${key}" "${value}" > "${temporary_file}"
    fi

    mv "${temporary_file}" "${file}"
}

managed_state_dir() {
    printf '%s\n' "${repo_root}/.codex/local-environment-state"
}

managed_database_state_file() {
    printf '%s\n' "$(managed_state_dir)/databases.env"
}

remember_database_target() {
    local role="${1}" connection="${2}" database="${3}" state_file

    mkdir -p "$(managed_state_dir)"
    state_file="$(managed_database_state_file)"

    set_env_file_value "${state_file}" "${role}_DB_CONNECTION" "${connection}"
    set_env_file_value "${state_file}" "${role}_DB_DATABASE" "${database}"
}

remember_original_file() {
    local target="${1}" backup="${2}"

    mkdir -p "$(managed_state_dir)"

    if [[ -f "${target}" && ! -f "${backup}" ]]; then
        cp "${target}" "${backup}"
    fi
}

remember_managed_checksum() {
    local target="${1}" checksum_file="${2}"

    if [[ -f "${target}" ]]; then
        cksum "${target}" > "${checksum_file}"
    fi
}

restore_managed_file() {
    local target="${1}" backup="${2}" checksum_file="${3}" expected_checksum current_checksum

    [[ -f "${backup}" ]] || return 0

    if [[ ! -f "${checksum_file}" ]]; then
        printf 'local-environment: leaving %s unchanged because no managed checksum exists.\n' "${target}" >&2

        return 0
    fi

    expected_checksum="$(cat "${checksum_file}")"
    current_checksum="$(cksum "${target}" 2>/dev/null || true)"

    if [[ "${current_checksum}" == "${expected_checksum}" ]]; then
        mv "${backup}" "${target}"
        rm -f "${checksum_file}"
    else
        printf 'local-environment: leaving modified %s in place; original backup remains at %s.\n' "${target}" "${backup}" >&2
    fi
}

cleanup_managed_state_dir() {
    local state_dir

    state_dir="$(managed_state_dir)"

    if [[ -d "${state_dir}" ]]; then
        rmdir "${state_dir}" 2>/dev/null || true
    fi
}

patch_phpunit_database() {
    local connection="${1}" database="${2}" state_dir backup checksum_file

    [[ -f phpunit.xml ]] || return 0

    state_dir="$(managed_state_dir)"
    backup="${state_dir}/phpunit.xml.backup"
    checksum_file="${state_dir}/phpunit.xml.cksum"

    remember_original_file phpunit.xml "${backup}"

    AI_HARNESS_TEST_DB_CONNECTION="${connection}" \
    AI_HARNESS_TEST_DB_DATABASE="${database}" \
    php_runtime -r '
        $path = "phpunit.xml";
        $connection = getenv("AI_HARNESS_TEST_DB_CONNECTION") ?: "sqlite";
        $database = getenv("AI_HARNESS_TEST_DB_DATABASE");

        if (! is_string($database) || $database === "") {
            fwrite(STDERR, "Missing testing database name.\n");
            exit(2);
        }

        $document = new DOMDocument();
        $document->preserveWhiteSpace = true;
        $document->formatOutput = true;

        if (! $document->load($path)) {
            fwrite(STDERR, "Unable to read phpunit.xml.\n");
            exit(2);
        }

        $php = $document->getElementsByTagName("php")->item(0);

        if (! $php instanceof DOMElement) {
            $php = $document->createElement("php");
            $document->documentElement?->appendChild($php);
        }

        $setEnv = function (string $name, string $value) use ($document, $php): void {
            foreach ($php->getElementsByTagName("env") as $env) {
                if ($env instanceof DOMElement && $env->getAttribute("name") === $name) {
                    $env->setAttribute("value", $value);
                    $env->setAttribute("force", "true");

                    return;
                }
            }

            $env = $document->createElement("env");
            $env->setAttribute("name", $name);
            $env->setAttribute("value", $value);
            $env->setAttribute("force", "true");
            $php->appendChild($env);
        };

        $setEnv("DB_CONNECTION", $connection);
        $setEnv("DB_DATABASE", $database);
        $setEnv("DB_URL", "");

        if ($document->save($path) === false) {
            fwrite(STDERR, "Unable to write phpunit.xml.\n");
            exit(2);
        }
    '

    remember_managed_checksum phpunit.xml "${checksum_file}"
}

restore_phpunit_database() {
    local state_dir

    state_dir="$(managed_state_dir)"

    restore_managed_file phpunit.xml "${state_dir}/phpunit.xml.backup" "${state_dir}/phpunit.xml.cksum"
    cleanup_managed_state_dir
}

sqlite_database_path() {
    local database_path="${1}"

    if [[ "${database_path}" = /* ]]; then
        printf '%s\n' "${database_path}"

        return
    fi

    printf '%s\n' "${repo_root}/${database_path}"
}

configure_worktree_environment() {
    local connection database_name sqlite_path

    codex_workspace_requested || return 0
    [[ -f .env ]] || return 0

    if herd_workspace_requested; then
        set_env_value APP_URL "http://$(herd_site_name).test"
    fi

    connection="$(env_value DB_CONNECTION || true)"
    connection="${connection:-sqlite}"
    database_name="$(worktree_database_name)"
    set_env_value DB_URL ""

    case "${connection}" in
        sqlite)
            sqlite_path="database/${database_name}.sqlite"
            set_env_value DB_DATABASE "${sqlite_path}"
            mkdir -p "$(dirname "$(sqlite_database_path "${sqlite_path}")")"
            touch "$(sqlite_database_path "${sqlite_path}")"
            remember_database_target APP "${connection}" "${sqlite_path}"
            ;;
        mysql|mariadb)
            set_env_value DB_DATABASE "${database_name}"
            create_mysql_database "${database_name}"
            remember_database_target APP "${connection}" "${database_name}"
            ;;
        *)
            printf 'local-environment: unsupported DB_CONNECTION=%s for managed Codex worktree.\n' "${connection}" >&2
            return 1
            ;;
    esac

    configure_worktree_testing_database "${connection}"
}

configure_worktree_testing_database() {
    local connection="${1}" testing_database_name sqlite_path

    testing_database_name="$(worktree_testing_database_name)"

    case "${connection}" in
        sqlite)
            sqlite_path="database/${testing_database_name}.sqlite"
            set_env_value AI_HARNESS_TEST_DB_DATABASE "${sqlite_path}"
            mkdir -p "$(dirname "$(sqlite_database_path "${sqlite_path}")")"
            touch "$(sqlite_database_path "${sqlite_path}")"
            remember_database_target TEST "${connection}" "${sqlite_path}"
            patch_phpunit_database "${connection}" "${sqlite_path}"
            ;;
        mysql|mariadb)
            set_env_value AI_HARNESS_TEST_DB_DATABASE "${testing_database_name}"
            create_mysql_database "${testing_database_name}"
            remember_database_target TEST "${connection}" "${testing_database_name}"
            patch_phpunit_database "${connection}" "${testing_database_name}"
            ;;
        *)
            printf 'local-environment: unsupported DB_CONNECTION=%s for managed Codex testing database.\n' "${connection}" >&2
            return 1
            ;;
    esac
}

migrate_testing_database() {
    local connection testing_database

    codex_workspace_requested || return 0
    [[ -f artisan ]] || return 0
    [[ -f .env ]] || return 0

    connection="$(env_value DB_CONNECTION || true)"
    connection="${connection:-sqlite}"
    testing_database="$(env_value AI_HARNESS_TEST_DB_DATABASE || true)"

    [[ -n "${testing_database}" ]] || return 0

    DB_CONNECTION="${connection}" \
    DB_DATABASE="${testing_database}" \
    DB_URL="" \
    artisan migrate --env=testing --force --ansi
}

create_mysql_database() {
    local database_name="${1}"

    AI_HARNESS_DB_HOST="$(env_value DB_HOST || printf '127.0.0.1')" \
    AI_HARNESS_DB_PORT="$(env_value DB_PORT || printf '3306')" \
    AI_HARNESS_DB_USERNAME="$(env_value DB_USERNAME || printf 'root')" \
    AI_HARNESS_DB_PASSWORD="$(env_value DB_PASSWORD || true)" \
    AI_HARNESS_DB_DATABASE="${database_name}" \
    AI_HARNESS_DB_CHARSET="${database_charset}" \
    AI_HARNESS_DB_COLLATION="${database_collation}" \
    php_runtime -r '
        $database = getenv("AI_HARNESS_DB_DATABASE");
        $charset = getenv("AI_HARNESS_DB_CHARSET") ?: "utf8mb4";
        $collation = getenv("AI_HARNESS_DB_COLLATION") ?: "utf8mb4_unicode_ci";

        foreach ([$database, $charset, $collation] as $value) {
            if (! is_string($value) || preg_match("/^[A-Za-z0-9_]+$/", $value) !== 1) {
                fwrite(STDERR, "Invalid database identifier.\n");
                exit(2);
            }
        }

        $dsn = sprintf(
            "mysql:host=%s;port=%s",
            getenv("AI_HARNESS_DB_HOST") ?: "127.0.0.1",
            getenv("AI_HARNESS_DB_PORT") ?: "3306"
        );

        $pdo = new PDO($dsn, getenv("AI_HARNESS_DB_USERNAME") ?: "root", getenv("AI_HARNESS_DB_PASSWORD") ?: "");
        $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
        $pdo->exec(sprintf("CREATE DATABASE IF NOT EXISTS `%s` CHARACTER SET %s COLLATE %s", $database, $charset, $collation));
    '
}

drop_worktree_database() {
    local connection database_name testing_database_name configured_database configured_testing_database state_file status

    codex_workspace_requested || return 0

    state_file="$(managed_database_state_file)"

    if [[ -f "${state_file}" ]]; then
        status=0

        drop_recorded_database \
            "$(file_env_value "${state_file}" APP_DB_CONNECTION || true)" \
            "$(file_env_value "${state_file}" APP_DB_DATABASE || true)" || status=$?

        drop_recorded_database \
            "$(file_env_value "${state_file}" TEST_DB_CONNECTION || true)" \
            "$(file_env_value "${state_file}" TEST_DB_DATABASE || true)" || status=$?

        if [[ "${status}" -eq 0 ]]; then
            rm -f "${state_file}"
        fi

        return "${status}"
    fi

    [[ -f .env ]] || return 0

    connection="$(env_value DB_CONNECTION || true)"
    connection="${connection:-sqlite}"
    database_name="$(worktree_database_name)"
    testing_database_name="$(worktree_testing_database_name)"
    configured_database="$(env_value DB_DATABASE || true)"
    configured_testing_database="$(env_value AI_HARNESS_TEST_DB_DATABASE || true)"

    case "${connection}" in
        sqlite)
            if [[ "${configured_testing_database}" == "database/${testing_database_name}.sqlite" || "${configured_testing_database}" == */"${testing_database_name}.sqlite" ]]; then
                remove_recorded_sqlite_database "${configured_testing_database}"
            fi

            if [[ "${configured_database}" == "database/${database_name}.sqlite" || "${configured_database}" == */"${database_name}.sqlite" ]]; then
                remove_recorded_sqlite_database "${configured_database}"
            fi
            ;;
        mysql|mariadb)
            if [[ "${configured_testing_database}" == "${testing_database_name}" ]]; then
                drop_mysql_database "${testing_database_name}"
            fi

            if [[ "${configured_database}" == "${database_name}" ]]; then
                drop_mysql_database "${database_name}"
            fi
            ;;
    esac
}

remove_recorded_sqlite_database() {
    local database="${1}" sqlite_path app_path test_path

    sqlite_path="$(sqlite_database_path "${database}")"
    app_path="$(sqlite_database_path "database/$(worktree_database_name).sqlite")"
    test_path="$(sqlite_database_path "database/$(worktree_testing_database_name).sqlite")"

    case "${sqlite_path}" in
        "${app_path}"|"${test_path}")
            rm -f "${sqlite_path}"
            ;;
        *)
            printf 'local-environment: refusing to remove unmanaged sqlite database path: %s\n' "${sqlite_path}" >&2
            return 1
            ;;
    esac
}

drop_recorded_database() {
    local connection="${1}" database="${2}"

    [[ -n "${connection}" ]] || return 0
    [[ -n "${database}" ]] || return 0

    case "${connection}" in
        sqlite)
            remove_recorded_sqlite_database "${database}"
            ;;
        mysql|mariadb)
            drop_mysql_database "${database}"
            ;;
    esac
}

drop_mysql_database() {
    local database_name="${1}"

    AI_HARNESS_DB_HOST="$(env_value DB_HOST || printf '127.0.0.1')" \
    AI_HARNESS_DB_PORT="$(env_value DB_PORT || printf '3306')" \
    AI_HARNESS_DB_USERNAME="$(env_value DB_USERNAME || printf 'root')" \
    AI_HARNESS_DB_PASSWORD="$(env_value DB_PASSWORD || true)" \
    AI_HARNESS_DB_DATABASE="${database_name}" \
    php_runtime -r '
        $database = getenv("AI_HARNESS_DB_DATABASE");

        if (! is_string($database) || preg_match("/^[A-Za-z0-9_]+$/", $database) !== 1) {
            fwrite(STDERR, "Invalid database identifier.\n");
            exit(2);
        }

        $dsn = sprintf(
            "mysql:host=%s;port=%s",
            getenv("AI_HARNESS_DB_HOST") ?: "127.0.0.1",
            getenv("AI_HARNESS_DB_PORT") ?: "3306"
        );

        $pdo = new PDO($dsn, getenv("AI_HARNESS_DB_USERNAME") ?: "root", getenv("AI_HARNESS_DB_PASSWORD") ?: "");
        $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
        $pdo->exec(sprintf("DROP DATABASE IF EXISTS `%s`", $database));
    '
}

link_herd_workspace() {
    if herd_workspace_requested; then
        herd link "$(herd_site_name)" --no-interaction
    fi
}

unlink_herd_workspace() {
    if herd_workspace_requested; then
        local output site_name status

        site_name="$(herd_site_name)"

        set +e
        output="$(herd unlink "${site_name}" 2>&1)"
        status=$?
        set -e

        if [[ "${status}" -eq 0 ]]; then
            if [[ -n "${output}" ]]; then
                printf '%s\n' "${output}"
            fi

            return 0
        fi

        if printf '%s\n' "${output}" | grep -Eiq '(not found|not linked|does not exist|no .*link)'; then
            return 0
        fi

        printf '%s\n' "${output}" >&2

        return "${status}"
    fi
}

app_key_missing() {
    if [[ ! -f .env ]]; then
        return 1
    fi

    local app_key_line
    app_key_line="$(grep -E '^APP_KEY=' .env | tail -n 1 || true)"

    local app_key="${app_key_line#APP_KEY=}"
    app_key="${app_key%\"}"
    app_key="${app_key#\"}"
    app_key="${app_key%\'}"
    app_key="${app_key#\'}"

    [[ -z "${app_key}" ]]
}

case "${action}" in
    setup)
        cd "${repo_root}"

        link_herd_workspace

        if [[ ! -f .env && -f .env.example ]]; then
            cp .env.example .env
        fi

        configure_worktree_environment

        if [[ ! -f vendor/autoload.php && -f composer.json ]] && composer_runtime_available; then
            composer_runtime install --no-interaction --prefer-dist
        fi

        if [[ -f artisan ]] && app_key_missing; then
            artisan key:generate --ansi
        fi

        if [[ -f artisan ]]; then
            DB_URL="" artisan migrate --force --ansi
        fi

        migrate_testing_database

        if [[ -f artisan ]]; then
            artisan ai-harness:doctor
        fi
        ;;
    cleanup)
        cd "${repo_root}"

        status=0
        drop_worktree_database || status=$?
        restore_phpunit_database || status=$?
        unlink_herd_workspace || status=$?

        exit "${status}"
        ;;
    *)
        printf 'local-environment: unknown action %s\n' "${action}" >&2
        exit 2
        ;;
esac
