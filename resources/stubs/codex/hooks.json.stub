{
    "hooks": {
        "SessionStart": [
            {
                "matcher": "startup",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"$(git rev-parse --show-toplevel)/.codex/scripts/local-environment.sh\" setup",
                        "timeout": 600,
                        "statusMessage": {{ codex_status_message_json }}
                    }
                ]
            }
        ]
    }
}
