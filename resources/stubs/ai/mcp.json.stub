{
    "mcpServers": {
        "laravel-boost": {
            "command": "sh",
            "args": [
                "-lc",
                "repo_root=\"$(git -C \"${CODEX_WORKTREE_PATH:-.}\" rev-parse --show-toplevel)\" && cd \"$repo_root\" && exec \"$repo_root/.dev/bin/ai-harness\" boost:mcp"
            ]
        }
    }
}
